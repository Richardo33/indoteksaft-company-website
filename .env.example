# Application
NODE_ENV=development
SITE_URL=http://localhost:3000
CONTACT_ALLOWED_ORIGIN=http://localhost:3000
APP_PORT=3000

# Contact delivery
# Optional: keep empty if you only want to store submissions in PostgreSQL.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_TOKEN=

# Contact database
CONTACT_DATABASE_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=indoteksaft_company
DB_USER=indoteksaft
DB_PASSWORD=change-this-database-password
DB_SSLMODE=disable

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_SYNC_SECRET=change-this-sanity-sync-secret-min-24-chars

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
