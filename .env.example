# Public canonical URL used by server-side metadata, sitemap, and origin checks.
SITE_URL=http://localhost:3000

# Optional production contact provider. Keep these server-only (no NEXT_PUBLIC_ prefix).
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_TOKEN=

# Optional explicit browser origin allowed to call the contact API.
CONTACT_ALLOWED_ORIGIN=http://localhost:3000

# Basic single-instance fallback. Use a distributed rate limiter at the gateway in production.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
