# Application
NODE_ENV=development
SITE_URL=http://localhost:3000
CONTACT_ALLOWED_ORIGIN=http://localhost:3000
APP_PORT=3000

# Contact delivery
# Optional: keep empty if you only want to store submissions in PostgreSQL.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_TOKEN=

# Contact email notification via SMTP
# Use your company SMTP/Google Workspace credentials.
CONTACT_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FORCE_IPV4=true
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM="Indoteksaft Website <noreply@example.com>"
SALES_NOTIFICATION_EMAIL=sales@example.com

# Contact database
CONTACT_DATABASE_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=indoteksaft_company
DB_USER=indoteksaft
DB_PASSWORD=change-this-database-password
DB_SSLMODE=disable

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-30
NEXT_PUBLIC_SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_PREVIEW_SECRET=change-this-preview-secret-min-24-chars
SANITY_SYNC_SECRET=change-this-sanity-sync-secret-min-24-chars

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
